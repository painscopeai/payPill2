# Browser (anon key only — never service role in NEXT_PUBLIC_*)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Admin UI fetch timeout in ms (default 120000). Form Builder bulk saves may need this headroom.
# NEXT_PUBLIC_API_FETCH_TIMEOUT_MS=120000

# Optional: API base URL for browser fetch() (default is same-origin `/api`).
# Use site origin only if Route Handlers live at /api on this app (we append /api automatically).
# Use a full path if the API is elsewhere, e.g. https://api.example.com or https://other.com/v1
# NEXT_PUBLIC_API_BASE_URL=https://your-app.vercel.app

# Server-only (Route Handlers / express-api — set in Vercel for Production, not NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend (provider application emails — optional; omit locally to skip send)
# RESEND_API_KEY=re_xxx
# RESEND_FROM=PayPill <onboarding@yourdomain.com>
# Comma-separated inbox(es) for new submitted applications
# PROVIDER_APPLICATION_NOTIFY_TO=ops@yourdomain.com

# Provider onboarding invite links (JWT HS256). Required to send invitation emails.
# PROVIDER_APPLICATION_INVITE_SECRET=your-long-random-secret

# Public origin of the SPA (invite emails link here), no trailing slash — e.g. https://paypill.vercel.app
# NEXT_PUBLIC_APP_ORIGIN=https://your-app.vercel.app

# Optional client encryption helper
# NEXT_PUBLIC_ENCRYPTION_KEY=

# API CORS when using external API origin; Next + bundled express uses permissive CORS by default
# CORS_ORIGIN=https://your-web-origin.example.com

# AI recommendations — async n8n flow:
# - PayPill POSTs one body: source, version, userPrompt (pretty JSON of clinical data), plus schemaVersion, userId, fetchedAt, counts, onboardingSteps[], healthRecords[] (no account/profile identity).
# - Waits only for a fast HTTP 2xx ACK (default 12s server-side).
# - Your n8n workflow must respond quickly (e.g. Respond-to-Webhook before Gemini), then run Gemini and INSERT rows into `patient_recommendations` for `userId` (typically Supabase HTTP node + service role).
# Webhook URL (optional override; code defaults to silentminds if unset):
# N8N_AI_RECOMMENDATIONS_WEBHOOK_URL=https://silentminds.app.n8n.cloud/webhook/ai
# Optional shared secret — sent as X-PayPill-Webhook-Secret (configure the same in n8n).
# N8N_AI_WEBHOOK_SECRET=
# Server: max time to wait for n8n to ACK the POST (ms, default 12000). Not the AI generation time.
# N8N_WEBHOOK_ACK_TIMEOUT_MS=12000
# Browser: POST /api/ai-recommendations timeout while waiting for ACK (ms, default 30000).
# NEXT_PUBLIC_AI_RECOMMENDATIONS_POST_TIMEOUT_MS=30000

# Gemini API key still used by GET /api/ai-recommendations/diagnostic (connection probe only).
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
