# Browser (anon key only — never service role in NEXT_PUBLIC_*)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: separate API origin (default is same-origin /api on this Next app)
# NEXT_PUBLIC_API_BASE_URL=https://your-api-host.example.com

# Server-only (Route Handlers / express-api — set in Vercel for Production, not NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional client encryption helper
# NEXT_PUBLIC_ENCRYPTION_KEY=

# API CORS when using external API origin; Next + bundled express uses permissive CORS by default
# CORS_ORIGIN=https://your-web-origin.example.com
