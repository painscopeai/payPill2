# Copy to .env locally. Do not commit real secrets.

# CORS — optional locally (defaults to reflecting request origin). Set in production (e.g. https://paypill.vercel.app).
# CORS_ORIGIN=http://localhost:3000

# Server / legacy (still used by unmigrated Express routes)
WEBSITE_DOMAIN=localhost

# Supabase — service role is server-only (Vercel / API env). Not required until API verifies JWT or uses Supabase from Node.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# PocketBase superuser (legacy; remove when Express no longer uses PocketBase)
PB_SUPERUSER_EMAIL=
PB_SUPERUSER_PASSWORD=
